// VoxLogicA-2 Dataset API Test Script
// This script demonstrates the dataset API functionality by:
// 1. Loading a directory of rotated medical images (.nii.gz files)
// 2. Applying thresholding operations using dynamic compilation
// 3. Saving the processed results

// Define the dataset path (update this to match your generated dataset)
let dataset_path = "/tmp/test_medical_dataset"

// Load the dataset from directory
let medical_images = dataset.readdir(dataset_path)

// Define a thresholding function that will be dynamically compiled
// This function takes an image and applies binary thresholding at 0.5
let threshold_func(image) = threshold(image, 0.5)

// Apply the thresholding function to all images in the dataset
// This demonstrates dynamic compilation with content-addressed IDs
let thresholded_images = dataset.map medical_images threshold_func

// Define a more complex processing function that combines operations
let complex_processing(image) = gaussian_blur(threshold(image, 0.3), 1.0)

// Apply complex processing to demonstrate dynamic compilation with multiple operations
let processed_images = dataset.map medical_images complex_processing

// Save the results
// The thresholded results
save "thresholded_results.json" thresholded_images

// The complex processed results  
save "processed_results.json" processed_images

// For demonstration, also process a subset with rotation-specific logic
let rotation_specific_func(image) = edge_detect(contrast_enhance(image, 1.2))

let enhanced_images = dataset.map medical_images rotation_specific_func

// Save the rotation-enhanced results
save "enhanced_results.json" enhanced_images

// Print summary information
print "Dataset processing completed"
print "Original dataset size" (count medical_images)
print "Thresholded images generated" (count thresholded_images)
print "Complex processed images generated" (count processed_images)  
print "Enhanced images generated" (count enhanced_images)
