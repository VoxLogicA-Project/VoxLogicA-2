// VoxLogicA-2 Dataset API Basic Test Script
// This script demonstrates the dataset API functionality using simple operations

// Import the dataset namespace
import "dataset"

// Load the dataset from directory - this will create Dask bags
let files = dataset.readdir("/tmp/test_dataset_simple")

// Define a simple function that operates on numeric data
let multiply_by_two(x) = multiplication(x, 2)

// Apply the function to all items in the dataset
// This demonstrates dynamic compilation with content-addressed IDs
let doubled_values = dataset.map(files, multiply_by_two)

// Save the results
save "doubled_results.json" doubled_values

// Print confirmation
print "test" "Dataset processing test completed"
