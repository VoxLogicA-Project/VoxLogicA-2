import "simpleitk"
import "vox1"

N(a) = near(a)
touch(a,b) = through(N(b), a)
// Distance operators
pdt(x) = mask(dt(x),dt(x) > 0)
distgeq(x,y) = x <= pdt(y)
distleq(x,y) = x >= pdt(y)

// More advanced functions
smoothen(a,x) = distleq(x,distgeq(x,not(a)))
dataset_root = "/home/VoxLogicA/datasets/BraTS_2019_HGG"

// Run the fixed-threshold segmentation on a small slice of the dataset.
dataset_slice_start = 0
dataset_slice_stop = 5
dataset_small_slice_stop = 5
hi_thr = 0.93
vi_thr = 0.88

all_flair_paths = dir(dataset_root, "*_flair.nii.gz", true, true)
flair_paths = subsequence(all_flair_paths, dataset_slice_start, dataset_slice_stop)

read_image(path) = ReadImage(path)
to_intensity(img) = intensity(img)
preprocess_flair(flair) =
  let background = touch(leq_sv(0.1, flair), border(flair)) in
  let brain = not(background) in
  percentiles(flair, brain, 0)

segment_case(pflair) =
  let hyper_intense = smoothen(geq_sv(hi_thr, pflair), 5.0) in
  let very_intense = smoothen(geq_sv(vi_thr, pflair), 2.0) in
  grow(hyper_intense, very_intense)

process_path(path) =
  let img = read_image(path) in
  let pflair = preprocess_flair(to_intensity(img)) in
  segment_case(pflair)

// Using for construct to iterate over dataset paths and compute volumes
result = map(process_path,flair_paths)
  //for path in flair_paths do
  //let seg = process_path(path) in
  //volume(seg)

print "result" map(volume,subsequence(result,dataset_slice_start,dataset_small_slice_stop))