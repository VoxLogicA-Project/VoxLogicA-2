import "simpleitk"

dataset_root = "/home/VoxLogicA/datasets/BraTS_2019_HGG"

// Run the fixed-threshold segmentation on a small slice of the dataset.
dataset_slice_start = 0
dataset_slice_stop = 5
dataset_small_slice_stop = 5
//mm = MinimumMaximum(img)
//lo = index(mm,0)
//hi = index(mm,1)

all_paths = dir(dataset_root, "*_flair.nii.gz", true, true)
paths = subsequence(all_paths, dataset_slice_start, dataset_slice_stop)

// Build 100 fractional thresholds linearly spaced between lo and hi (inclusive).
idxs = range(0,100)

// BinaryThreshold semantics:
// keep voxel if lower <= intensity <= upper
// Here upper=hi, so increasing lower keeps only brighter voxels.
// mk_mask(th) = BinaryThreshold(img, th, hi, 255, 0)

// Keep the sweep symbolic and side-effect free.
// masks = map(mk_mask, thresholds)

result = for path in paths do
    let img = ReadImage(path) in
        let mm = MinimumMaximum(img) in
            let lo = index(mm,0) in
                let hi = index(mm,1) in
                    let thresholds = lo + (hi-lo) * (idxs / 99) in
                    for th in thresholds do
                        let imgTh = BinaryThreshold(img, th, hi, 255, 0) in
                        volume(imgTh)


print "result" subsequence(result,dataset_slice_start,dataset_small_slice_stop)